# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (Email sending)
RESEND_API_KEY=re_...
EMAIL_FROM=SkillFeed <hello@yourdomain.com>

# AgentMail (Email ingestion)
AGENTMAIL_API_KEY=your-agentmail-api-key
AGENTMAIL_WEBHOOK_SECRET=your-webhook-secret

# Cron security
CRON_SECRET=your-cron-secret

# JWT secret for unsubscribe tokens
JWT_SECRET=your-jwt-secret

# App URL (used for webhook registration, unsubscribe links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Newsletter composer: "llm" (default, personalized per-user) or "template" (zero LLM)
NEWSLETTER_COMPOSER_MODE=llm
# Include "why it matters" per article in template mode (default: true)
NEWSLETTER_INCLUDE_WHY_IT_MATTERS=true
# Include roadmap/next-steps in template mode (default: true)
NEWSLETTER_INCLUDE_ROADMAP=true
